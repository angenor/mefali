# Database
DATABASE_URL=postgres://mefali:mefali@localhost:5433/mefali

# Redis
REDIS_URL=redis://localhost:6380

# MinIO (S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=mefali
MINIO_SECRET_KEY=mefali_secret
MINIO_BUCKET=mefali-files

# API
API_HOST=0.0.0.0
API_PORT=8090

# JWT
JWT_SECRET=dev-secret-change-in-prod
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# CinetPay
CINETPAY_API_KEY=votre_api_key
CINETPAY_SITE_ID=votre_site_id
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2
CINETPAY_NOTIFY_URL=https://api.mefali.ci/api/v1/payments/webhook?secret=votre_webhook_secret
CINETPAY_RETURN_URL=https://api.mefali.ci/payment/return
CINETPAY_WEBHOOK_SECRET=votre_webhook_secret

# Firebase Cloud Messaging (FCM) — optional, push notifications disabled if not set
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# SMS Gateway — dual-provider for delivery mission fallback (NFR28)
# Swap DevSmsProvider for real providers in production
# SMS_PRIMARY_PROVIDER=infobip
# SMS_PRIMARY_API_KEY=your_infobip_api_key
# SMS_PRIMARY_SENDER=mefali
# SMS_FALLBACK_PROVIDER=twilio
# SMS_FALLBACK_API_KEY=your_twilio_api_key
# SMS_FALLBACK_SENDER=mefali

# Share/Referral — base URL for WhatsApp share links
SHARE_BASE_URL=https://api.mefali.ci

# Logging
RUST_LOG=info,api=debug
