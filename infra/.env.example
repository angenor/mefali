# Contrat du .env (data-model.md §4). Copier en `.env` (jamais commité) et
# renseigner. Aucune valeur sensible ici (constitution VIII).
# En dev, les valeurs par défaut ci-dessous correspondent au docker-compose.yml.

# --- Postgres (seule vérité durable) ---
POSTGRES_USER=mefali
POSTGRES_PASSWORD=change-me-en-dev
POSTGRES_DB=mefali
DATABASE_URL=postgres://mefali:change-me-en-dev@localhost:5432/mefali

# --- Redis (éphémère uniquement) ---
REDIS_URL=redis://localhost:6379

# --- Garage (stockage objet, API S3) ---
# Secret RPC (32 octets hex) : générer avec `openssl rand -hex 32`.
GARAGE_RPC_SECRET=
# Jeton d'administration Garage (init du layout, création buckets/clés).
GARAGE_ADMIN_TOKEN=
# Clé d'accès dédiée au backend (créée par infra/garage/init.sh — à recopier ici).
S3_ENDPOINT=http://localhost:3900
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=mefali

# --- OSRM (routage — consommé par les cycles suivants) ---
OSRM_URL=http://localhost:5000

# --- Observabilité (TRX-03) ---
# Vide = Sentry désactivé (dev). En prod : DSN du projet Sentry.
SENTRY_DSN=
# dev | production (protège Swagger UI hors dev — constitution VIII)
APP_ENV=dev

# --- Sauvegardes (TRX-04) — consommées par infra/backups/ uniquement ---
# Bucket S3 tiers (Backblaze B2) : immutabilité/object lock côté bucket externe.
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_BUCKET=
# Clé Garage dédiée au job de backup (lecture seule sur le bucket applicatif).
BACKUP_GARAGE_ACCESS_KEY=
BACKUP_GARAGE_SECRET_KEY=
# Clé PUBLIQUE age (destinataire du chiffrement). La clé PRIVÉE reste HORS VPS.
BACKUP_AGE_RECIPIENT=
