{
  "openapi": "3.1.0",
  "info": {
    "title": "Mefali API",
    "version": "0.1.0"
  },
  "paths": {
    "/admin/zones/{zone_id}/categories/{categorie_slug}/forcage": {
      "put": {
        "tags": [
          "zones"
        ],
        "summary": "Force l'état d'une catégorie dans une ville (ZON-02). Journalisé via outbox\n(categorie.forcage_change + categorie.activation_changee si bascule) dans la\nmême transaction.",
        "operationId": "forcer_categorie",
        "parameters": [
          {
            "name": "zone_id",
            "in": "path",
            "description": "Ville dont on force la catégorie.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "categorie_slug",
            "in": "path",
            "description": "Slug de la catégorie.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CorpsForcage"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Nouveau mode appliqué ; état effectif.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EtatCategorie"
                }
              }
            }
          },
          "401": {
            "description": "Jeton admin absent ou invalide."
          },
          "404": {
            "description": "Zone ou catégorie inconnue."
          },
          "422": {
            "description": "Corps invalide (forcage hors énumération)."
          }
        },
        "security": [
          {
            "adminToken": []
          }
        ]
      }
    },
    "/health": {
      "get": {
        "tags": [
          "socle"
        ],
        "summary": "Sonde de vie du service. Répond `200 {status:\"ok\", version}`.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service opérationnel",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CorpsForcage": {
        "type": "object",
        "description": "Corps de la requête de forçage.",
        "required": [
          "forcage"
        ],
        "properties": {
          "forcage": {
            "$ref": "#/components/schemas/ForcageDto",
            "description": "Nouveau mode de forçage à appliquer."
          }
        }
      },
      "EtatCategorie": {
        "type": "object",
        "description": "État effectif d'une catégorie renvoyé après forçage (contrat).",
        "required": [
          "zone",
          "categorie",
          "forcage",
          "actif"
        ],
        "properties": {
          "actif": {
            "type": "boolean",
            "description": "État EFFECTIF après application."
          },
          "categorie": {
            "type": "string",
            "description": "Slug de la catégorie."
          },
          "forcage": {
            "$ref": "#/components/schemas/ForcageDto",
            "description": "Mode de forçage appliqué."
          },
          "zone": {
            "type": "string",
            "format": "uuid",
            "description": "Ville concernée."
          }
        }
      },
      "ForcageDto": {
        "type": "string",
        "description": "Mode de forçage (contrat) — mappé sur [`zones::Forcage`].",
        "enum": [
          "automatique",
          "force_actif",
          "force_inactif"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "description": "Réponse de la sonde de vie. Ne contient AUCUNE donnée sensible : la sonde\nmesure la disponibilité du processus (non authentifiée, constitution VIII).",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "Toujours `\"ok\"` quand le processus répond.",
            "example": "ok"
          },
          "version": {
            "type": "string",
            "description": "Version du binaire (`CARGO_PKG_VERSION`)."
          }
        }
      }
    },
    "securitySchemes": {
      "adminToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Admin-Token"
      }
    }
  }
}
