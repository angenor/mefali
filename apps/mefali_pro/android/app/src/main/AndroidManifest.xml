<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Toute la valeur de l'app passe par l'API (OTP, /config, dossier) : sans
         INTERNET elle ne fait rien. Flutter ne la déclare que dans src/debug et
         src/profile (l'outillage en a besoin pour le hot reload) — une RELEASE
         partirait donc sans réseau, et échouerait dès l'écran du téléphone. -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Volontairement ABSENTE : android.permission.CAMERA.
         image_picker ne prend pas la photo lui-même, il délègue par intent à
         l'app Appareil photo, qui porte ses propres permissions (« Android: No
         configuration required », README image_picker 1.2.3). La DÉCLARER
         inverserait le résultat : Android exige alors qu'elle soit accordée à
         l'exécution avant ACTION_IMAGE_CAPTURE, et rien ici ne la demande (pas
         de permission_handler dans le projet) — la caméra lèverait une
         SecurityException. Vérifié sur ÉMULATEUR (Android 15 / API 36, photo de
         pièce du dossier coursier, CPT-04) : sans cette permission, l'app
         Appareil photo s'ouvre et rend la photo sans un mot. Pas encore rejoué
         sur un téléphone physique.

         RECORD_AUDIO n'est pas listée non plus, mais elle EST dans l'apk : le
         manifest de record_android la déclare et le merger la fusionne. Le
         plugin `record` la demande lui-même au runtime
         (`note_vocale.dart` → `_micro.hasPermission()`). La redéclarer ici ne
         changerait rien à l'apk et laisserait croire qu'on la pilote. -->

    <application
        android:label="@string/app_name"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
