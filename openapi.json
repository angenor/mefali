{
  "openapi": "3.1.0",
  "info": {
    "title": "Mefali API",
    "version": "0.1.0"
  },
  "paths": {
    "/admin/zones/{zone_id}/categories/{categorie_slug}/forcage": {
      "put": {
        "tags": [
          "zones"
        ],
        "summary": "Force l'état d'une catégorie dans une ville (ZON-02). Journalisé via outbox\n(categorie.forcage_change + categorie.activation_changee si bascule) dans la\nmême transaction.",
        "operationId": "forcer_categorie",
        "parameters": [
          {
            "name": "zone_id",
            "in": "path",
            "description": "Ville dont on force la catégorie.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "categorie_slug",
            "in": "path",
            "description": "Slug de la catégorie.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CorpsForcage"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Nouveau mode appliqué ; état effectif.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EtatCategorie"
                }
              }
            }
          },
          "401": {
            "description": "Session absente, invalide ou révoquée."
          },
          "403": {
            "description": "Rôle admin requis."
          },
          "404": {
            "description": "Zone ou catégorie inconnue."
          },
          "422": {
            "description": "Corps invalide (forcage hors énumération)."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/auth/deconnexion": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Révoque la session courante (déconnexion locale).",
        "operationId": "deconnexion",
        "responses": {
          "204": {
            "description": "Session révoquée."
          },
          "401": {
            "description": "Session absente, invalide ou révoquée.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/auth/inscription": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Crée le compte après consentement ARTCI, puis ouvre sa session.",
        "operationId": "inscrire",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Inscription"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Compte créé (réduit au numéro vérifié) + session ouverte.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultatVerification"
                }
              }
            }
          },
          "401": {
            "description": "Jeton d'inscription invalide, expiré (10 min) ou déjà consommé.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          },
          "422": {
            "description": "Consentement absent — aucun compte n'est créé (FR-006).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        }
      }
    },
    "/auth/otp/demander": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Demande l'envoi d'un code OTP. Réponse TOUJOURS neutre (SC-003).",
        "operationId": "demander",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DemandeOtp"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Réponse UNIQUE : numéro connu ou non, plafond atteint ou non. Chaque demande invalide le code précédent du numéro.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Accepte"
                }
              }
            }
          },
          "422": {
            "description": "Numéro non normalisable — erreur de FORMAT, neutre quant à l'existence d'un compte.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        }
      }
    },
    "/auth/otp/verifier": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Vérifie le code : ouvre une session (numéro connu) ou exige le consentement.",
        "operationId": "verifier",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerificationOtp"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Vérification réussie — deux issues discriminées par `resultat`.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultatVerification"
                }
              }
            }
          },
          "401": {
            "description": "Code faux, expiré (> 5 min) ou essais épuisés (3) — message NEUTRE unique, identique dans TOUS les cas d'échec.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          },
          "422": {
            "description": "Numéro non normalisable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        }
      }
    },
    "/auth/rafraichir": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Échange le refresh contre un nouvel accès (rotation systématique, R2).",
        "operationId": "rafraichir",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DemandeRafraichissement"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Nouveaux jetons — l'ancien refresh est invalidé. Aucune expiration d'inactivité.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JetonsDto"
                }
              }
            }
          },
          "401": {
            "description": "Refresh inconnu, session révoquée, OU réutilisation d'un jeton déjà tourné —                                       dans ce dernier cas la session est RÉVOQUÉE (détection de vol, R2).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        }
      }
    },
    "/config": {
      "get": {
        "tags": [
          "zones"
        ],
        "summary": "Configuration produit publique d'une zone (ZON-04). PUBLIC en lecture seule\n(clarification Q1), liste blanche de namespaces (R4), versionnée par ETag\n(304 sur If-None-Match — polling horaire économe).",
        "operationId": "config",
        "parameters": [
          {
            "name": "zone",
            "in": "query",
            "description": "Zone dont on veut la configuration effective.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Configuration effective résolue.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigZone"
                }
              }
            }
          },
          "304": {
            "description": "Non modifiée (If-None-Match == version)."
          },
          "400": {
            "description": "Paramètre zone absent ou UUID invalide."
          },
          "404": {
            "description": "Zone inconnue — erreur explicite, jamais une config vide."
          },
          "429": {
            "description": "Rate-limit dépassé."
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "socle"
        ],
        "summary": "Sonde de vie du service. Répond `200 {status:\"ok\", version}`.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Service opérationnel",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/moi": {
      "get": {
        "tags": [
          "moi"
        ],
        "summary": "Compte courant et états de TOUS ses rôles.",
        "operationId": "moi",
        "responses": {
          "200": {
            "description": "Compte courant.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CompteMoi"
                }
              }
            }
          },
          "401": {
            "description": "Session absente, invalide ou révoquée.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/moi/sessions": {
      "get": {
        "tags": [
          "moi"
        ],
        "summary": "Appareils/sessions actifs du compte (FR-008).",
        "operationId": "mes_sessions",
        "responses": {
          "200": {
            "description": "Appareils actifs.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionAppareil"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Session absente, invalide ou révoquée.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/moi/sessions/{session_id}": {
      "delete": {
        "tags": [
          "moi"
        ],
        "summary": "Déconnexion à distance d'un appareil (SC-004).",
        "operationId": "revoquer_session",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "description": "Appareil à déconnecter.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Session révoquée — événement `session.revoquee` émis."
          },
          "401": {
            "description": "Session absente, invalide ou révoquée.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          },
          "404": {
            "description": "Session inconnue ou n'appartenant pas au compte.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErreurApi"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Accepte": {
        "type": "object",
        "description": "Réponse UNIQUE de `/auth/otp/demander`.",
        "required": [
          "message_cle"
        ],
        "properties": {
          "message_cle": {
            "type": "string",
            "description": "Toujours `comptes.otp.envoye_si_valide`.",
            "example": "comptes.otp.envoye_si_valide"
          }
        }
      },
      "AppareilDto": {
        "type": "object",
        "description": "Appareil déclaré par l'app à l'ouverture de session.",
        "required": [
          "nom",
          "plateforme"
        ],
        "properties": {
          "nom": {
            "type": "string",
            "description": "Nom lisible (« Pixel 7 de poche »), affiché tel quel dans la liste.",
            "maxLength": 80
          },
          "plateforme": {
            "$ref": "#/components/schemas/PlateformeDto",
            "description": "Plateforme."
          }
        }
      },
      "CategorieDto": {
        "type": "object",
        "description": "Catégorie active (contrat).",
        "required": [
          "slug",
          "nom_cle",
          "mixable"
        ],
        "properties": {
          "mixable": {
            "type": "boolean",
            "description": "Mixable au panier (CMD-01)."
          },
          "nom_cle": {
            "type": "string",
            "description": "Clé i18n fr du nom."
          },
          "slug": {
            "type": "string",
            "description": "Slug de la catégorie."
          }
        }
      },
      "CompteMoi": {
        "type": "object",
        "description": "Compte courant et l'état de TOUS ses rôles (contrat `CompteMoi`).",
        "required": [
          "id",
          "telephone_e164",
          "zone_id",
          "roles",
          "cree_le"
        ],
        "properties": {
          "cree_le": {
            "type": "string",
            "format": "date-time",
            "description": "Création du compte."
          },
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Identifiant du compte."
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EtatRoleDto"
            },
            "description": "Rôles et leurs statuts (tous, pas seulement les valides)."
          },
          "telephone_e164": {
            "type": "string",
            "description": "Identité Mefali — aucune donnée nominative au MVP."
          },
          "zone_id": {
            "type": "string",
            "format": "uuid",
            "description": "Zone de rattachement."
          }
        }
      },
      "ConfigZone": {
        "type": "object",
        "description": "Document `/config` (contrat) — sous-ensemble public de la config effective.",
        "required": [
          "zone",
          "version",
          "devise",
          "drapeaux",
          "categories",
          "transports_actifs",
          "textes",
          "parametres"
        ],
        "properties": {
          "categories": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CategorieDto"
            },
            "description": "Catégories actives dans la zone."
          },
          "devise": {
            "$ref": "#/components/schemas/DeviseDto",
            "description": "Devise résolue."
          },
          "drapeaux": {
            "type": "object",
            "description": "Drapeaux (clés `drapeau.*` sans préfixe).",
            "additionalProperties": {
              "type": "boolean"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "parametres": {
            "type": "object",
            "description": "Paramètres client (clés `client.*` sans préfixe)."
          },
          "textes": {
            "type": "object",
            "description": "Textes (clés `texte.*` sans préfixe) — clés i18n fr.",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "transports_actifs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Slugs des types de transport actifs."
          },
          "version": {
            "type": "string",
            "description": "Empreinte SHA-256 hex du document canonique (= ETag)."
          },
          "zone": {
            "type": "string",
            "format": "uuid",
            "description": "Zone servie."
          }
        }
      },
      "CorpsForcage": {
        "type": "object",
        "description": "Corps de la requête de forçage.",
        "required": [
          "forcage"
        ],
        "properties": {
          "forcage": {
            "$ref": "#/components/schemas/ForcageDto",
            "description": "Nouveau mode de forçage à appliquer."
          }
        }
      },
      "DemandeOtp": {
        "type": "object",
        "description": "Corps de `POST /auth/otp/demander`.",
        "required": [
          "telephone",
          "zone"
        ],
        "properties": {
          "telephone": {
            "type": "string",
            "description": "Saisie locale ou E.164 — normalisée avec l'indicatif de la zone (R4)."
          },
          "zone": {
            "type": "string",
            "format": "uuid",
            "description": "Zone de l'app (bootstrap Tiassalé — R13)."
          }
        }
      },
      "DemandeRafraichissement": {
        "type": "object",
        "description": "Corps de `POST /auth/rafraichir`.",
        "required": [
          "rafraichissement"
        ],
        "properties": {
          "rafraichissement": {
            "type": "string",
            "description": "Jeton de renouvellement opaque courant."
          }
        }
      },
      "DeviseDto": {
        "type": "object",
        "description": "Devise (contrat) — montants entiers en unités mineures (principe III).",
        "required": [
          "code",
          "decimales"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Code ISO 4217 (ex. XOF)."
          },
          "decimales": {
            "type": "integer",
            "format": "int32",
            "description": "Nombre de décimales des unités mineures (0 pour XOF).",
            "minimum": 0
          }
        }
      },
      "ErreurApi": {
        "type": "object",
        "description": "Corps d'erreur du contrat — `{ code, message_cle }`.",
        "required": [
          "code",
          "message_cle"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Code stable, exploitable par le client."
          },
          "message_cle": {
            "type": "string",
            "description": "Clé i18n fr — aucune chaîne UI en dur (constitution VII)."
          }
        }
      },
      "EtatCategorie": {
        "type": "object",
        "description": "État effectif d'une catégorie renvoyé après forçage (contrat).",
        "required": [
          "zone",
          "categorie",
          "forcage",
          "actif"
        ],
        "properties": {
          "actif": {
            "type": "boolean",
            "description": "État EFFECTIF après application."
          },
          "categorie": {
            "type": "string",
            "description": "Slug de la catégorie."
          },
          "forcage": {
            "$ref": "#/components/schemas/ForcageDto",
            "description": "Mode de forçage appliqué."
          },
          "zone": {
            "type": "string",
            "format": "uuid",
            "description": "Ville concernée."
          }
        }
      },
      "EtatRoleDto": {
        "type": "object",
        "description": "État d'un rôle (contrat).",
        "required": [
          "role",
          "statut"
        ],
        "properties": {
          "decide_le": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time",
            "description": "Horodatage de la dernière décision."
          },
          "motif": {
            "type": [
              "string",
              "null"
            ],
            "description": "Motif de la dernière décision admin."
          },
          "role": {
            "type": "string",
            "description": "Rôle concerné."
          },
          "statut": {
            "type": "string",
            "description": "Statut courant."
          }
        }
      },
      "ForcageDto": {
        "type": "string",
        "description": "Mode de forçage (contrat) — mappé sur [`zones::Forcage`].",
        "enum": [
          "automatique",
          "force_actif",
          "force_inactif"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "description": "Réponse de la sonde de vie. Ne contient AUCUNE donnée sensible : la sonde\nmesure la disponibilité du processus (non authentifiée, constitution VIII).",
        "required": [
          "status",
          "version"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "Toujours `\"ok\"` quand le processus répond.",
            "example": "ok"
          },
          "version": {
            "type": "string",
            "description": "Version du binaire (`CARGO_PKG_VERSION`)."
          }
        }
      },
      "Inscription": {
        "type": "object",
        "description": "Corps de `POST /auth/inscription`.",
        "required": [
          "jeton_inscription",
          "consentement_version"
        ],
        "properties": {
          "consentement_version": {
            "type": "string",
            "description": "Version du texte ARTCI accepté — servie par la config de zone."
          },
          "jeton_inscription": {
            "type": "string",
            "description": "Émis par `/auth/otp/verifier`, usage unique, TTL 10 min."
          }
        }
      },
      "JetonsDto": {
        "type": "object",
        "description": "Paire de jetons (contrat).",
        "required": [
          "acces",
          "rafraichissement"
        ],
        "properties": {
          "acces": {
            "type": "string",
            "description": "JWT HS256, 15 min (claims sub/sid)."
          },
          "rafraichissement": {
            "type": "string",
            "description": "Opaque 256 bits — tourne à chaque usage."
          }
        }
      },
      "PlateformeDto": {
        "type": "string",
        "description": "Plateforme de l'appareil (contrat).",
        "enum": [
          "android",
          "ios"
        ]
      },
      "ResultatVerification": {
        "oneOf": [
          {
            "type": "object",
            "description": "Numéro connu — session ouverte.",
            "required": [
              "jetons",
              "compte",
              "resultat"
            ],
            "properties": {
              "compte": {
                "$ref": "#/components/schemas/CompteMoi",
                "description": "Compte connecté."
              },
              "jetons": {
                "$ref": "#/components/schemas/JetonsDto",
                "description": "Jetons de l'appareil."
              },
              "resultat": {
                "type": "string",
                "enum": [
                  "session"
                ]
              }
            }
          },
          {
            "type": "object",
            "description": "Numéro inconnu — consentement ARTCI exigé avant création (FR-006).",
            "required": [
              "jeton_inscription",
              "resultat"
            ],
            "properties": {
              "jeton_inscription": {
                "type": "string",
                "description": "Jeton d'inscription à usage unique."
              },
              "resultat": {
                "type": "string",
                "enum": [
                  "consentement_requis"
                ]
              }
            }
          }
        ],
        "description": "Issue de `/auth/otp/verifier` — `oneOf` discriminé par `resultat`."
      },
      "SessionAppareil": {
        "type": "object",
        "description": "Session/appareil du compte (contrat `SessionAppareil`).",
        "required": [
          "id",
          "appareil_nom",
          "appareil_plateforme",
          "cree_le",
          "derniere_activite_le",
          "courante"
        ],
        "properties": {
          "appareil_nom": {
            "type": "string",
            "description": "Nom déclaré par l'app."
          },
          "appareil_plateforme": {
            "$ref": "#/components/schemas/PlateformeDto",
            "description": "Plateforme."
          },
          "courante": {
            "type": "boolean",
            "description": "Session de l'appareil appelant — celle qu'on ne se coupe pas par erreur."
          },
          "cree_le": {
            "type": "string",
            "format": "date-time",
            "description": "Ouverture."
          },
          "derniere_activite_le": {
            "type": "string",
            "format": "date-time",
            "description": "Dernier rafraîchissement."
          },
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Identifiant de session."
          }
        }
      },
      "VerificationOtp": {
        "type": "object",
        "description": "Corps de `POST /auth/otp/verifier`.",
        "required": [
          "telephone",
          "zone",
          "code",
          "appareil"
        ],
        "properties": {
          "appareil": {
            "$ref": "#/components/schemas/AppareilDto",
            "description": "Appareil — capté ici, conservé jusqu'à l'inscription (R3)."
          },
          "code": {
            "type": "string",
            "description": "Code à 6 chiffres.",
            "pattern": "^[0-9]{6}$"
          },
          "telephone": {
            "type": "string",
            "description": "Le MÊME numéro que celui de la demande."
          },
          "zone": {
            "type": "string",
            "format": "uuid",
            "description": "Zone de l'app."
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
